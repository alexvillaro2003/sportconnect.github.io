@'
# Build outputs
bin/
obj/
out/

# Visual Studio
.vs/
*.user
*.suo
*.userprefs
*.dbmdl
*.jfm

# Rider
.idea/
*.sln.iml

# VS Code
.vscode/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
!**/packages/build/

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# DB local (SQLite)
*.db
*.db-shm
*.db-wal

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log

# Certificados / secretos
*.pfx
appsettings.Development.json
secrets.json
'@ | Out-File -FilePath .gitignore -Encoding utf8