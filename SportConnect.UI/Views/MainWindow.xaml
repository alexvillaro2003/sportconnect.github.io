<Window x:Class="SportConnect.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SportConnect.UI.Views"
        Title="SportConnect"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ─────────────────────────────────────────────────────── -->
        <Grid Grid.Column="0" Background="#0F172A">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Logo -->
            <TextBlock Grid.Row="0"
                       Text="SportConnect"
                       FontSize="18" FontWeight="Bold"
                       Foreground="White"
                       Margin="20,20,20,32" />

            <!-- Nav buttons -->
            <StackPanel Grid.Row="1" Margin="8,0">
                <RadioButton Content="Discover"
                             GroupName="Sidebar"
                             IsChecked="{Binding SelectedTabIndex,
                                         Converter={StaticResource IntEqualityConverter},
                                         ConverterParameter=0}"
                             Style="{StaticResource SidebarNavButton}" />

                <RadioButton Content="My Activities"
                             GroupName="Sidebar"
                             IsChecked="{Binding SelectedTabIndex,
                                         Converter={StaticResource IntEqualityConverter},
                                         ConverterParameter=1}"
                             Style="{StaticResource SidebarNavButton}" />

                <RadioButton Content="Profile"
                             GroupName="Sidebar"
                             IsChecked="{Binding SelectedTabIndex,
                                         Converter={StaticResource IntEqualityConverter},
                                         ConverterParameter=2}"
                             Style="{StaticResource SidebarNavButton}" />

                <RadioButton Content="Admin"
                             GroupName="Sidebar"
                             IsChecked="{Binding SelectedTabIndex,
                                         Converter={StaticResource IntEqualityConverter},
                                         ConverterParameter=3}"
                             Visibility="{Binding IsAdmin,
                                          Converter={StaticResource NullToVisibilityConverter}}"
                             Style="{StaticResource SidebarNavButton}" />
            </StackPanel>

            <!-- Bottom: refresh + avatar + username + logout -->
            <StackPanel Grid.Row="2" Margin="8,0,8,16">
                <Border Height="1" Background="#1E293B" Margin="4,0,4,12" />

                <Button Content="↻ Refresh"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SidebarActionButton}"
                        Margin="0,0,0,4" />

                <StackPanel Orientation="Horizontal" Margin="12,0,0,10">
                    <Grid Width="36" Height="36" VerticalAlignment="Center" Margin="0,0,10,0">
                        <!-- Fallback: orange circle with username initial -->
                        <Ellipse Fill="{StaticResource PrimaryBrush}" />
                        <TextBlock Text="{Binding CurrentUsername,
                                           Converter={StaticResource StringToInitialConverter}}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="White" FontWeight="Bold" FontSize="14" />
                        <!-- Photo overlay: visible only when CurrentUserPhoto is set -->
                        <Ellipse Visibility="{Binding CurrentUserPhoto,
                                              Converter={StaticResource NullToVisibilityConverter}}">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="{Binding CurrentUserPhoto}"
                                            Stretch="UniformToFill" />
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>
                    <TextBlock Text="{Binding CurrentUsername, StringFormat='Hi, {0}'}"
                               Foreground="#94A3B8"
                               FontSize="13"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Button Content="Logout"
                        Command="{Binding LogoutCommand}"
                        Style="{StaticResource SidebarActionButton}" />
            </StackPanel>
        </Grid>

        <!-- ── Content area ────────────────────────────────────────────────── -->
        <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" Padding="32,28,32,28">
            <Grid>

                <Grid Visibility="{Binding SelectedTabIndex,
                                   Converter={StaticResource IntToVisibilityConverter},
                                   ConverterParameter=0}">
                    <views:ActivityFeedView DataContext="{Binding Feed}" />
                </Grid>

                <Grid Visibility="{Binding SelectedTabIndex,
                                   Converter={StaticResource IntToVisibilityConverter},
                                   ConverterParameter=1}">
                    <views:MyActivitiesView DataContext="{Binding MyActivities}" />
                </Grid>

                <Grid Visibility="{Binding SelectedTabIndex,
                                   Converter={StaticResource IntToVisibilityConverter},
                                   ConverterParameter=2}">
                    <views:ProfileView DataContext="{Binding Profile}" />
                </Grid>

                <Grid Visibility="{Binding SelectedTabIndex,
                                   Converter={StaticResource IntToVisibilityConverter},
                                   ConverterParameter=3}">
                    <views:AdminView DataContext="{Binding Admin}" />
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Window>
