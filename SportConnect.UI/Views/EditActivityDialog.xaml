<Window x:Class="SportConnect.UI.Views.EditActivityDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Activity"
        Height="480" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Edit Activity"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}"
                   Margin="0,0,0,20" />

        <!-- Form -->
        <StackPanel Grid.Row="1">

            <TextBlock Text="Sport" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding Sports}"
                      SelectedItem="{Binding SelectedSport}"
                      DisplayMemberPath="Name"
                      Margin="0,0,0,14" />

            <TextBlock Text="Location" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
            <TextBox Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,14" />

            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="56" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="56" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Date" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <DatePicker SelectedDate="{Binding ScheduledDate}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Hour" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Hours}"
                              SelectedItem="{Binding ScheduledHour}"
                              IsEditable="False" />
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Min" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Minutes}"
                              SelectedItem="{Binding ScheduledMinute}"
                              IsEditable="False" />
                </StackPanel>
            </Grid>

            <TextBlock Text="Max players" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
            <TextBox Text="{Binding MaxPlayersText, UpdateSourceTrigger=PropertyChanged}"
                     Width="80" HorizontalAlignment="Left"
                     Margin="0,0,0,14" />

            <TextBlock Text="Description (optional)" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource ErrorBrush}"
                       TextWrapping="Wrap" Margin="0,12,0,0"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Padding="16,10" Margin="0,0,10,0"
                    Cursor="Hand"
                    Background="Transparent"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" />
            <Button Content="Save changes"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
        </StackPanel>
    </Grid>
</Window>
