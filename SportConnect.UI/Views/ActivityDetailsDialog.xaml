<Window x:Class="SportConnect.UI.Views.ActivityDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Activity Details"
        Height="720" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="{Binding Activity.Sport.Name}"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}"
                   Margin="0,0,0,20" />

        <!-- Details -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <TextBlock Text="Location"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2" />
                <TextBlock Text="{Binding Activity.Location}" Margin="0,0,0,12" />

                <TextBlock Text="Date &amp; Time"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2" />
                <TextBlock Text="{Binding Activity.ScheduledAt, StringFormat='{}{0:dd MMM yyyy  HH:mm}'}"
                           Margin="0,0,0,12" />

                <TextBlock Text="Organizer"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2" />
                <TextBlock Text="{Binding Activity.Creator.Username}" Margin="0,0,0,12" />

                <TextBlock Text="Spots"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2" />
                <TextBlock Text="{Binding SpotsText}" Margin="0,0,0,12" />

                <TextBlock Text="Description"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"
                           Visibility="{Binding Activity.Description, Converter={StaticResource NullToVisibilityConverter}}" />
                <TextBlock Text="{Binding Activity.Description}"
                           TextWrapping="Wrap" Margin="0,0,0,12"
                           Visibility="{Binding Activity.Description, Converter={StaticResource NullToVisibilityConverter}}" />

                <TextBlock Text="Participants"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                <ItemsControl ItemsSource="{Binding JoinedParticipants}" Margin="0,0,0,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding User.Username}" Margin="0,0,0,2" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Chat section -->
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                        Margin="0,16,0,0" Padding="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="Activity Chat"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,12" />

                        <ScrollViewer Height="180" Margin="0,0,0,12"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Messages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding SentAt, StringFormat='[{0:HH:mm}]'}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="12"
                                                           Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding User.Username}"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource PrimaryBrush}"
                                                           Margin="0,0,6,0" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Content}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Margin="12,2,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Message input (only when chat is active) -->
                        <Grid Visibility="{Binding IsChatActive, Converter={StaticResource NullToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Text="{Binding NewMessageContent, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="Type a message..."
                                     Margin="0,0,8,0">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Resources>
                                            <VisualBrush x:Key="Hint" TileMode="None" Stretch="None" AlignmentX="Left">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="{Binding Path=Tag,
                                                               RelativeSource={RelativeSource AncestorType=TextBox}}"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               Margin="12,8,0,0" />
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Style.Resources>
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background" Value="{StaticResource Hint}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <Button Grid.Column="1"
                                    Content="Send"
                                    Command="{Binding SendMessageCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="12,8"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                        </Grid>

                        <!-- Chat closed notice -->
                        <TextBlock Visibility="{Binding IsChatClosed, Converter={StaticResource NullToVisibilityConverter}}"
                                   Text="Chat closed. This activity has ended."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontStyle="Italic" />
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorBrush}"
                           TextWrapping="Wrap" Margin="0,12,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Button x:Name="DeleteButton"
                    Content="Delete"
                    Click="DeleteButton_Click"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                    Visibility="{Binding CanManage, Converter={StaticResource NullToVisibilityConverter}}"
                    HorizontalAlignment="Left"
                    Background="{StaticResource ErrorBrush}"
                    Foreground="White"
                    Padding="16,10"
                    Cursor="Hand"
                    BorderThickness="0" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="EditButton"
                    Content="Edit"
                    Click="EditButton_Click"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                    Visibility="{Binding CanManage, Converter={StaticResource NullToVisibilityConverter}}"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White"
                    Padding="16,10"
                    Margin="0,0,10,0"
                    Cursor="Hand"
                    BorderThickness="0" />
            <Button Content="Close"
                    Command="{Binding CloseDialogCommand}"
                    Padding="16,10" Margin="0,0,10,0"
                    Cursor="Hand"
                    Background="Transparent"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" />

            <!-- Join button: visible when not a participant and activity is not full -->
            <Button Content="Join"
                    Command="{Binding JoinCommand}"
                    IsEnabled="{Binding CanJoin}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsParticipant}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Leave button: visible when already a participant -->
            <Button Content="Leave"
                    Command="{Binding LeaveCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsParticipant}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
